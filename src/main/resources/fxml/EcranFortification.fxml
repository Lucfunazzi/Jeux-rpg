<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="lancement.gui.EcranFortificationController"
      alignment="CENTER" spacing="16" styleClass="root-menu">
    <Label text="FORTIFICATION" styleClass="titre"/>
    <Label text="Renforcez vos equipements en depensant de l'or.&#10;Chaque niveau double les stats de la piece."
           styleClass="texte" wrapText="true" maxWidth="420"/>
    <Label fx:id="infoLabel" styleClass="texte"/>

    <VBox alignment="CENTER" spacing="8">
        <padding><Insets top="10"/></padding>
        <Button text="Fortifier un equipement equipe" onAction="#onFortifierEquipe" styleClass="menu-bouton"/>
        <Button text="Fortifier un equipement dans l'inventaire" onAction="#onFortifierInventaire" styleClass="menu-bouton"/>
    </VBox>

    <Button text="Retour" onAction="#onRetour" styleClass="menu-bouton">
        <VBox.margin><Insets top="10"/></VBox.margin>
    </Button>
</VBox>
