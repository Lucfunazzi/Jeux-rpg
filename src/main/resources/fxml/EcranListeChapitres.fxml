<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="lancement.gui.EcranListeChapitresController"
            styleClass="root-menu">
    <top>
        <Label fx:id="titreLabel" styleClass="titre" BorderPane.alignment="CENTER">
            <BorderPane.margin><Insets top="20" bottom="10"/></BorderPane.margin>
        </Label>
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <VBox fx:id="lignesBox" alignment="CENTER" spacing="16">
                <padding><Insets top="10" bottom="10" left="30" right="30"/></padding>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <VBox alignment="CENTER" spacing="10">
            <padding><Insets top="10" bottom="20"/></padding>
            <Button text="Retour" onAction="#onRetour" styleClass="menu-bouton"/>
        </VBox>
    </bottom>
</BorderPane>
