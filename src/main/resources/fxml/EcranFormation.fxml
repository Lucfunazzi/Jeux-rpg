<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="lancement.gui.EcranFormationController"
            styleClass="root-menu">
    <top>
        <Label text="FORMATION" styleClass="titre" BorderPane.alignment="CENTER">
            <BorderPane.margin><Insets top="20" bottom="10"/></BorderPane.margin>
        </Label>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="10">
            <padding><Insets left="30" right="30"/></padding>
            <Label fx:id="tankLabel" styleClass="texte" wrapText="true"/>
            <Label fx:id="attaquantsLabel" styleClass="texte" wrapText="true"/>
            <Label fx:id="supportsLabel" styleClass="texte" wrapText="true"/>
            <Label fx:id="competenceLabel" styleClass="texte" wrapText="true"/>
            <Label fx:id="liensLabel" styleClass="texte" wrapText="true"/>

            <VBox alignment="CENTER" spacing="8">
                <padding><Insets top="20"/></padding>
                <Button text="Ajouter un personnage" onAction="#onAjouter" styleClass="menu-bouton"/>
                <Button text="Retirer un personnage" onAction="#onRetirer" styleClass="menu-bouton"/>
                <Button text="Voir les statistiques" onAction="#onVoirStats" styleClass="menu-bouton"/>
                <Button text="Changer la competence speciale" onAction="#onChangerCompetence" styleClass="menu-bouton"/>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <VBox alignment="CENTER" spacing="10">
            <padding><Insets top="10" bottom="20"/></padding>
            <Button text="Retour" onAction="#onRetour" styleClass="menu-bouton"/>
        </VBox>
    </bottom>
</BorderPane>
