<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="lancement.gui.EcranFichePersonnageController"
            styleClass="root-menu">
    <top>
        <Label fx:id="titreLabel" styleClass="titre" BorderPane.alignment="CENTER" wrapText="true">
            <BorderPane.margin><Insets top="20" bottom="10" left="20" right="20"/></BorderPane.margin>
        </Label>
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <VBox alignment="CENTER" spacing="14">
                <padding><Insets top="10" bottom="10" left="30" right="30"/></padding>

                <Label fx:id="statsLabel" styleClass="texte" wrapText="true" maxWidth="480"/>
                <Label fx:id="liensLabel" styleClass="texte" wrapText="true" maxWidth="480"/>
                <Label fx:id="setLabel" styleClass="texte" wrapText="true" maxWidth="480"/>

                <VBox fx:id="slotsBox" alignment="CENTER" spacing="6">
                    <padding><Insets top="10"/></padding>
                </VBox>

                <Button fx:id="parcheminButton" onAction="#onParcheminXP" styleClass="menu-bouton" wrapText="true" prefWidth="320"/>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <VBox alignment="CENTER" spacing="10">
            <padding><Insets top="10" bottom="20"/></padding>
            <Button text="Retour" onAction="#onRetour" styleClass="menu-bouton"/>
        </VBox>
    </bottom>
</BorderPane>
