<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="lancement.gui.EcranChoixClasseController"
      alignment="CENTER" spacing="25" styleClass="root-menu">
    <Label text="CHOIX DE LA CLASSE" styleClass="titre"/>
    <Label fx:id="sousTitre" styleClass="texte"/>

    <GridPane hgap="20" vgap="20" alignment="CENTER">
        <Button fx:id="btnChevalier" onAction="#onChoixChevalier"
                styleClass="menu-bouton,classe-bouton" wrapText="true" textAlignment="CENTER"
                GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <Button fx:id="btnChasseur" onAction="#onChoixChasseur"
                styleClass="menu-bouton,classe-bouton" wrapText="true" textAlignment="CENTER"
                GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Button fx:id="btnMage" onAction="#onChoixMage"
                styleClass="menu-bouton,classe-bouton" wrapText="true" textAlignment="CENTER"
                GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <Button fx:id="btnConstellationniste" onAction="#onChoixConstellationniste"
                styleClass="menu-bouton,classe-bouton" wrapText="true" textAlignment="CENTER"
                GridPane.rowIndex="1" GridPane.columnIndex="1"/>
    </GridPane>

    <Button text="Retour" onAction="#onRetour" styleClass="menu-bouton"/>
</VBox>
