<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="lancement.gui.EcranAccueilController"
      alignment="CENTER" spacing="20" styleClass="root-menu">
    <Label text="FAIRY TAIL RPG" styleClass="titre"/>

    <VBox fx:id="pseudoBox" alignment="CENTER" spacing="12">
        <Label text="Entrez votre pseudo :" styleClass="texte"/>
        <HBox alignment="CENTER" spacing="10">
            <TextField fx:id="pseudoField" promptText="Aventurier" prefWidth="200"/>
            <Button text="Continuer" onAction="#onValiderPseudo" styleClass="menu-bouton"/>
        </HBox>
    </VBox>

    <VBox fx:id="choixBox" alignment="CENTER" spacing="12" visible="false" managed="false">
        <Label fx:id="statutLabel" styleClass="texte"/>
        <Button fx:id="chargerButton" text="Charger la partie" onAction="#onChargerPartie" styleClass="menu-bouton"/>
        <Button fx:id="nouvellePartieButton" text="Nouvelle partie" onAction="#onNouvellePartie" styleClass="menu-bouton"/>
    </VBox>

    <Button text="Quitter" onAction="#onQuitter" styleClass="menu-bouton"/>
</VBox>
