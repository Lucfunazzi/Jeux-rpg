<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="lancement.gui.EcranEtoilesController"
            styleClass="root-menu">
    <top>
        <Label text="ETOILES &amp; FRAGMENTS" styleClass="titre" BorderPane.alignment="CENTER">
            <BorderPane.margin><Insets top="20" bottom="10"/></BorderPane.margin>
        </Label>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="10">
            <padding><Insets left="30" right="30" top="10"/></padding>
            <TextArea fx:id="fragmentsArea" editable="false" wrapText="false"
                      styleClass="zone-mono" prefHeight="320"/>
        </VBox>
    </center>

    <bottom>
        <VBox alignment="CENTER" spacing="8">
            <padding><Insets top="10" bottom="20"/></padding>
            <Button text="Recruter via fragments" onAction="#onRecruter" styleClass="menu-bouton"/>
            <Button text="Monter en etoile un personnage" onAction="#onMonterEtoile" styleClass="menu-bouton"/>
            <Button text="Retour" onAction="#onRetour" styleClass="menu-bouton"/>
        </VBox>
    </bottom>
</BorderPane>
