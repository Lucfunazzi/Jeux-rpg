<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="lancement.gui.EcranEtoilesController"
            styleClass="root-menu">
    <top>
        <Label text="ÉTOILES &amp; FRAGMENTS" styleClass="titre" BorderPane.alignment="CENTER">
            <BorderPane.margin><Insets top="20" bottom="10"/></BorderPane.margin>
        </Label>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane" prefHeight="360">
            <padding><Insets left="30" right="30" top="10" bottom="10"/></padding>
            <VBox fx:id="contenuBox" spacing="8"/>
        </ScrollPane>
    </center>

    <bottom>
        <VBox alignment="CENTER" spacing="8">
            <padding><Insets top="10" bottom="20"/></padding>
            <Button text="Retour" onAction="#onRetour" styleClass="menu-bouton"/>
        </VBox>
    </bottom>
</BorderPane>
