<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="lancement.gui.EcranMenuPrincipalController"
            styleClass="root-menu">
    <top>
        <VBox alignment="CENTER" spacing="6">
            <padding><Insets top="20" bottom="10"/></padding>
            <Label text="MENU PRINCIPAL" styleClass="titre"/>
            <Label fx:id="enTeteLabel" styleClass="texte"/>
            <Label fx:id="ressourcesLabel" styleClass="texte"/>
            <Label fx:id="energieLabel" styleClass="texte"/>
            <VBox fx:id="xpBarBox" alignment="CENTER" spacing="2"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <VBox fx:id="boutonsBox" alignment="CENTER" spacing="8">
                <padding><Insets top="10" bottom="10" left="20" right="20"/></padding>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <VBox alignment="CENTER" spacing="10">
            <padding><Insets top="10" bottom="20"/></padding>
            <Button text="Sauvegarder" onAction="#onSauvegarder" styleClass="menu-bouton"/>
            <Button text="Quitter" onAction="#onQuitter" styleClass="menu-bouton"/>
        </VBox>
    </bottom>
</BorderPane>
